FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties.Chromium;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phaseState      condensed;  // or: gaseous, solid

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState adiabaticPerfectFluid;//rhoConst;//perfectFluid;
    specie          specie;
    energy          sensibleInternalEnergy;
}
// 316L alloy-specific phase change (Keep identical in all metal files)
TSolidus                1648.0;   // Solidus [K]
TLiquidus               1673.0;   // Liquidus [K]
LatentHeat              2.9e5;    // [J/kg]

// Electromagnetic properties (MHD)
elec_conductivity       1.45e6;   // [S/m]
magnetic_permeability   1.257e-6; // [H/m]

mixture
    {
        specie { molWeight 52.00; }
        equationOfState
        {
            p0      1e5;
            rho0    7190;
            gamma   1.1;
            B       1.6e11;
        }
        thermodynamics { Cp 450; Hf 0; }
        transport { mu 5.0e-3; Pr 0.018; }
    }


// ************************************************************************* //
