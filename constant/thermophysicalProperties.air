FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties.air;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Shielding gas: Argon (Ar)
// Properties at ~300 K and 1 atm
phaseState      gaseous;
thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleInternalEnergy;
}
TSolidus	5.0;
TLiquidus	10.0;
LatentHeat	1.0;
elec_conductivity	1.0;
magnetic_permeability	1.256e-6;
mixture
{
    specie
    {
        molWeight   39.948;     // Ar molecular weight (g/mol)
    }
    thermodynamics
    {
        Cp          520;        // J/kg/K - monatomic, constant over wide T range
        Hf          0;
    }
    transport
    {
        mu          2.27e-05;   // Pa.s - dynamic viscosity at 300 K
        Pr          0.67;       // Prandtl number at 300 K
    }
}
// ************************************************************************* //
